{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rapiddraft/schemas/part_facts.schema.json",
  "title": "Part Facts",
  "type": "object",
  "required": [
    "schema_version",
    "model_id",
    "component_node_name",
    "component_display_name",
    "generated_at",
    "coverage",
    "overall_confidence",
    "missing_inputs",
    "assumptions",
    "errors",
    "geometry_instances",
    "sections"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "component_node_name": {
      "type": "string"
    },
    "component_display_name": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "coverage": {
      "type": "object",
      "required": [
        "core_extraction_coverage",
        "full_rule_readiness_coverage"
      ],
      "properties": {
        "core_extraction_coverage": {
          "$ref": "#/$defs/coverageBlock"
        },
        "full_rule_readiness_coverage": {
          "$ref": "#/$defs/coverageBlock"
        }
      },
      "additionalProperties": false
    },
    "overall_confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "missing_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "geometry_instances": {
      "type": "object",
      "properties": {
        "internal_radius_instances": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/internalRadiusInstance"
          }
        },
        "hole_instances": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/holeInstance"
          }
        },
        "wall_thickness_instances": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/wallThicknessInstance"
          }
        }
      },
      "additionalProperties": false
    },
    "sections": {
      "type": "object",
      "required": [
        "geometry",
        "manufacturing_signals",
        "declared_context",
        "process_inputs",
        "rule_inputs"
      ],
      "properties": {
        "geometry": {
          "$ref": "#/$defs/metricMap"
        },
        "manufacturing_signals": {
          "$ref": "#/$defs/metricMap"
        },
        "declared_context": {
          "$ref": "#/$defs/metricMap"
        },
        "process_inputs": {
          "$ref": "#/$defs/metricMap"
        },
        "rule_inputs": {
          "$ref": "#/$defs/metricMap"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "coverageBlock": {
      "type": "object",
      "required": [
        "known_metrics",
        "applicable_metrics",
        "not_applicable_metrics",
        "total_metrics",
        "percent"
      ],
      "properties": {
        "known_metrics": {
          "type": "integer",
          "minimum": 0
        },
        "applicable_metrics": {
          "type": "integer",
          "minimum": 0
        },
        "not_applicable_metrics": {
          "type": "integer",
          "minimum": 0
        },
        "total_metrics": {
          "type": "integer",
          "minimum": 0
        },
        "percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": false
    },
    "metricMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/metric"
      }
    },
    "metric": {
      "type": "object",
      "required": [
        "label",
        "value",
        "unit",
        "state",
        "confidence",
        "source"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "value": {},
        "unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "type": "string",
          "enum": [
            "measured",
            "inferred",
            "declared",
            "unknown",
            "failed",
            "not_applicable"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "internalRadiusInstance": {
      "type": "object",
      "required": [
        "instance_id",
        "radius_mm",
        "aggravating_factor"
      ],
      "properties": {
        "instance_id": {
          "type": "string"
        },
        "edge_index": {
          "type": [
            "integer",
            "null"
          ]
        },
        "location_description": {
          "type": "string"
        },
        "radius_mm": {
          "type": "number"
        },
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "recommendation": {
          "type": [
            "string",
            "null"
          ]
        },
        "pocket_depth_mm": {
          "type": [
            "number",
            "null"
          ]
        },
        "depth_to_radius_ratio": {
          "type": [
            "number",
            "null"
          ]
        },
        "aggravating_factor": {
          "type": "boolean"
        },
        "position_mm": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "number"
          },
          "minItems": 3,
          "maxItems": 3
        },
        "bbox_bounds_mm": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "number"
          },
          "minItems": 6,
          "maxItems": 6
        }
      },
      "additionalProperties": false
    },
    "holeInstance": {
      "type": "object",
      "required": [
        "instance_id",
        "diameter_mm"
      ],
      "properties": {
        "instance_id": { "type": "string" },
        "subtype": { "type": ["string", "null"] },
        "location_description": { "type": "string" },
        "diameter_mm": { "type": "number" },
        "depth_mm": { "type": ["number", "null"] },
        "depth_to_diameter_ratio": { "type": ["number", "null"] },
        "position_mm": {
          "type": ["array", "null"],
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "bbox_bounds_mm": {
          "type": ["array", "null"],
          "items": { "type": "number" },
          "minItems": 6,
          "maxItems": 6
        },
        "face_indices": {
          "type": "array",
          "items": { "type": "integer" }
        }
      },
      "additionalProperties": false
    },
    "wallThicknessInstance": {
      "type": "object",
      "required": [
        "instance_id",
        "thickness_mm"
      ],
      "properties": {
        "instance_id": { "type": "string" },
        "location_description": { "type": "string" },
        "thickness_mm": { "type": "number" },
        "position_mm": {
          "type": ["array", "null"],
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "bbox_bounds_mm": {
          "type": ["array", "null"],
          "items": { "type": "number" },
          "minItems": 6,
          "maxItems": 6
        },
        "face_indices": {
          "type": "array",
          "items": { "type": "integer" }
        }
      },
      "additionalProperties": false
    }
  }
}
